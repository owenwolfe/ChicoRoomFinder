<!-- 
    INSTRUCTIONS TO RUN:

    1. Move all building_{1...n-1} into the same directory as this file (viewer.html). 
    For example, this example will be in ~/Downloads.
    2. cd ~/Downloads
    3. python3 -m http.server 8000
    4. Go on browser and open: http://localhost:8000/viewer.html?v=14
    5. Test different options for start/finish.
    6. Correct path will be output to a create file "route.json"
-->



<!doctype html>
<html>
    <head>
        <meta charset="utf-8">
        <title>Holt + Campus Viewer</title>
        <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
        <style>
html, body, #plot {
    width: 100%;
    height: 100%;
    margin: 0;
    font-family: sans-serif;
}
    #info {
        position: absolute;
        top: 10px;
        left: 10px;
        z-index: 10;
        background: rgba(255,255,255,0.97);
        border: 1px solid #ccc;
        padding: 10px 12px;
        max-width: 700px;
        line-height: 1.35;
    }
    #controls {
        margin-top: 8px;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 6px 8px;
        align-items: center;
    }
    input, button {
        font: inherit;
        padding: 6px 8px;
    }
    button {
        cursor: pointer;
    }
    .row {
        margin-top: 8px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .hint {
        margin-top: 8px;
        font-size: 12px;
        color: #444;
    }
    .mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
        </style>
    </head>
    <body>
        <div id="info">
            <div><strong>Holt combined graph with campus floor 0</strong></div>
            <div id="status">Loading…</div>

            <div id="controls">
                <label for="startInput">Start</label>
                <input id="startInput" value="Entrance 6 Outside">

                <label for="goalInput">Goal</label>
                <input id="goalInput" value="277@2">
            </div>

            <div class="row">
                <button id="runBtn">Run A*</button>
                <button id="resetBtn">Reset</button>
            </div>

            <div class="hint">
                Examples:
                <span class="mono">Entrance 6 Outside</span>,
                <span class="mono">Entrance 8 Outside</span>,
                <span class="mono">Entrance 6@1</span>,
                <span class="mono">135@1</span>,
                <span class="mono">277@2</span>,
                <span class="mono">Portal 1@2</span>,
                <span class="mono">north-stair-3@3</span><br>
                Floor 0 is campus. Campus is scaled to match Holt using file calibration. Each Holt floor-1 entrance gets its own outside approach node.
            </div>
        </div>

        <div id="plot"></div>

        <script>
            const FLOOR_GAP = 220;
            const STAIR_COST = 6.0;
            const ELEVATOR_COST = 4.0;
            const STEP_DELAY_MS = 140;
            const EXTERIOR_TO_CAMPUS_COST = 8.0;
            const EXTERIOR_TO_BUILDING_COST = 1.0;

            // If you later identify exact campus OSM node IDs for each entrance,
            // put them here and they will override nearest-node matching.
            // Example:
            // "Entrance 6": "osm-node-1234567890"
            const MANUAL_ENTRANCE_BINDINGS = {
                "Entrance 1": "osm-node-5861595676",
                "Entrance 2": "osm-node-5863721909",
                "Entrance 3": "osm-node-5861595671",
                "Entrance 4": "osm-node-12057911483",
                "Entrance 5": "osm-node-12016281847",
                "Entrance 6": "osm-node-12016281847",
                "Entrance 7": "osm-node-10123224954",
                "Entrance 8": "osm-node-10123224954"
            };

            const statusEl = document.getElementById("status");
            const startInput = document.getElementById("startInput");
            const goalInput = document.getElementById("goalInput");
            const runBtn = document.getElementById("runBtn");
            const resetBtn = document.getElementById("resetBtn");

            let floors = [];
            let allNodes = [];
            let nodeMap = new Map();
            let adjacency = new Map();

            let currentStartId = null;
            let currentGoalId = null;

            let baseNodeTrace = null;
            let baseWalkwayTrace = null;
            let baseStairTrace = null;
            let baseElevatorTrace = null;
            let baseEntryTrace = null;

            function sleep(ms) {
                return new Promise(resolve => setTimeout(resolve, ms));
            }

            function normalizeText(s) {
                return String(s || "").trim().toLowerCase();
            }

            function colorForKind(kind) {
                switch (kind) {
                    case "entrance": return "green";
                    case "destination": return "red";
                    case "junction": return "purple";
                    case "anchor": return "gray";
                    case "portal": return "cyan";
                    case "transition": return "gold";
                    default: return "blue";
                }
            }

            function visualZForFloor(floorLevel) {
                return floorLevel * FLOOR_GAP;
            }

            function namespacedId(floorLevel, nodeId) {
                return `${floorLevel}:${nodeId}`;
            }

            function parseLookup(text) {
                const raw = String(text || "").trim();
                const m = raw.match(/^(.*?)(?:@(\d+))?$/);
                return {
                    query: normalizeText(m ? m[1] : raw),
                    floor: m && m[2] ? Number(m[2]) : null
                };
            }

            function nodeKeys(node) {
                const keys = new Set();

                keys.add(normalizeText(node.label));
                keys.add(normalizeText(node.id));
                keys.add(normalizeText(node.uid));

                if (node.roomNumber != null) {
                    keys.add(normalizeText(node.roomNumber));
                }

                if (Array.isArray(node.aliases)) {
                    for (const a of node.aliases) keys.add(normalizeText(a));
                }

                if (node.label) keys.add(`${normalizeText(node.label)}@${node.floorLevel}`);
                if (node.roomNumber != null) keys.add(`${normalizeText(node.roomNumber)}@${node.floorLevel}`);

                return [...keys].filter(Boolean);
            }

            function findNodeByInput(text) {
                const lookup = parseLookup(text);
                const q = lookup.query;
                if (!q) return null;

                let candidates = allNodes.filter(n => {
                    if (lookup.floor != null && n.floorLevel !== lookup.floor) return false;
                    return nodeKeys(n).includes(q) || nodeKeys(n).includes(`${q}@${n.floorLevel}`);
                });

                if (candidates.length === 1) return candidates[0];
                if (candidates.length > 1) {
                    const exactLabel = candidates.find(n => normalizeText(n.label) === q);
                    if (exactLabel) return exactLabel;
                    const exactRoom = candidates.find(n => normalizeText(n.roomNumber) === q);
                    if (exactRoom) return exactRoom;
                    return candidates[0];
                }

                candidates = allNodes.filter(n => {
                    if (lookup.floor != null && n.floorLevel !== lookup.floor) return false;
                    return nodeKeys(n).some(k => k.includes(q));
                });

                return candidates[0] || null;
            }

            function addAdjEdge(fromId, toId, cost, kind, bidirectional = true) {
                if (!adjacency.has(fromId)) adjacency.set(fromId, []);
                adjacency.get(fromId).push({ to: toId, cost, kind });

                if (bidirectional) {
                    if (!adjacency.has(toId)) adjacency.set(toId, []);
                    adjacency.get(toId).push({ to: fromId, cost, kind });
                }
            }

            function addSyntheticNode(node) {
                allNodes.push(node);
                nodeMap.set(node.uid, node);
                adjacency.set(node.uid, []);
            }

            function distanceScaled(a, b) {
                const dx = a.x - b.x;
                const dy = a.y - b.y;
                return Math.hypot(dx, dy);
            }

            function pairNearestTransitions(lowerFloorNodes, upperFloorNodes) {
                const pairs = [];
                const usedUpper = new Set();

                for (const a of lowerFloorNodes) {
                    let bestIndex = -1;
                    let bestDist = Infinity;

                    for (let i = 0; i < upperFloorNodes.length; i++) {
                        if (usedUpper.has(i)) continue;
                        const b = upperFloorNodes[i];
                        const dx = a.raw.x - b.raw.x;
                        const dy = a.raw.y - b.raw.y;
                        const d = Math.hypot(dx, dy);
                        if (d < bestDist) {
                            bestDist = d;
                            bestIndex = i;
                        }
                    }

                    if (bestIndex >= 0) {
                        usedUpper.add(bestIndex);
                        pairs.push([a, upperFloorNodes[bestIndex]]);
                    }
                }

                return pairs;
            }

            function heuristic(aId, bId) {
                const a = nodeMap.get(aId);
                const b = nodeMap.get(bId);

                const dx = a.raw.x - b.raw.x;
                const dy = a.raw.y - b.raw.y;
                const ppm = a.pixelsPerMeter || 50;
                const planarMeters = Math.hypot(dx, dy) / ppm;
                const floorPenalty = Math.abs(a.floorLevel - b.floorLevel) * Math.min(STAIR_COST, ELEVATOR_COST);

                return planarMeters + floorPenalty;
            }

            function reconstructPath(cameFrom, current) {
                const path = [current];
                while (cameFrom.has(current)) {
                    current = cameFrom.get(current);
                    path.push(current);
                }
                return path.reverse();
            }

            function makeScatterForIds(name, ids, color, size) {
                return {
                    type: "scatter3d",
                    mode: "markers",
                    name,
                    x: ids.map(id => nodeMap.get(id).x),
                    y: ids.map(id => nodeMap.get(id).y),
                    z: ids.map(id => nodeMap.get(id).z),
                    text: ids.map(id => {
                        const n = nodeMap.get(id);
                        return `${n.label || n.id} @ floor ${n.floorLevel} [${n.kind}]`;
                    }),
                    hoverinfo: "text",
                    marker: { size, color }
                };
            }

            function makePathTrace(pathIds, name, color, width) {
                return {
                    type: "scatter3d",
                    mode: "lines+markers",
                    name,
                    x: pathIds.map(id => nodeMap.get(id).x),
                    y: pathIds.map(id => nodeMap.get(id).y),
                    z: pathIds.map(id => nodeMap.get(id).z),
                    hoverinfo: "none",
                    line: { color, width },
                    marker: { color, size: 5 }
                };
            }

            function buildLineTrace(edges, name, color, width) {
                const x = [], y = [], z = [];
                for (const e of edges) {
                    const a = nodeMap.get(e.from);
                    const b = nodeMap.get(e.to);
                    if (!a || !b) continue;
                    x.push(a.x, b.x, null);
                    y.push(a.y, b.y, null);
                    z.push(a.z, b.z, null);
                }
                return {
                    type: "scatter3d",
                    mode: "lines",
                    name,
                    x, y, z,
                    hoverinfo: "none",
                    line: { color, width }
                };
            }

            function render(openIds = [], closedIds = [], currentId = null, pathIds = []) {
                const traces = [
                    baseWalkwayTrace,
                    baseStairTrace,
                    baseElevatorTrace,
                    baseEntryTrace,
                    baseNodeTrace,
                    makeScatterForIds("open set", openIds, "orange", 7),
                    makeScatterForIds("closed set", closedIds, "lightgray", 6),
                    makeScatterForIds("start", currentStartId ? [currentStartId] : [], "lime", 10),
                    makeScatterForIds("goal", currentGoalId ? [currentGoalId] : [], "red", 10),
                    makeScatterForIds("current", currentId ? [currentId] : [], "black", 11),
                    makePathTrace(pathIds, "path", "magenta", 8)
                ];

                Plotly.react("plot", traces, {
                    margin: { l: 0, r: 0, t: 0, b: 0 },
                    scene: {
                        aspectmode: "data",
                        camera: { eye: { x: 1.5, y: -1.7, z: 1.2 } }
                    },
                    legend: { x: 0.01, y: 0.99 }
                }, { responsive: true });
            }

            async function runAStar() {
                const startNode = findNodeByInput(startInput.value);
                const goalNode = findNodeByInput(goalInput.value);

                if (!startNode || !goalNode) {
                    statusEl.textContent = "Start or goal not found. Try Entrance 6 Outside, 135, 277@2, Entrance 8@1, Portal 1@2.";
                    return;
                }

                currentStartId = startNode.uid;
                currentGoalId = goalNode.uid;

                const openSet = new Set([currentStartId]);
                const closedSet = new Set();
                const cameFrom = new Map();
                const gScore = new Map();
                const fScore = new Map();

                for (const n of allNodes) {
                    gScore.set(n.uid, Infinity);
                    fScore.set(n.uid, Infinity);
                }

                gScore.set(currentStartId, 0);
                fScore.set(currentStartId, heuristic(currentStartId, currentGoalId));

                let step = 0;

                while (openSet.size > 0) {
                    let current = null;
                    let bestF = Infinity;

                    for (const id of openSet) {
                        const f = fScore.get(id);
                        if (f < bestF) {
                            bestF = f;
                            current = id;
                        }
                    }

                    const currentNode = nodeMap.get(current);
                    const previewPath = reconstructPath(cameFrom, current);

                    statusEl.textContent =
                        `Step ${step}: ${currentNode.label || currentNode.id} on floor ${currentNode.floorLevel} | open=${openSet.size} closed=${closedSet.size} f=${bestF.toFixed(2)}`;

                    render([...openSet], [...closedSet], current, previewPath);
                    await sleep(STEP_DELAY_MS);

                    if (current === currentGoalId) {
                        const finalPath = reconstructPath(cameFrom, current);

                        const routeText = finalPath.map(id => {
                            const n = nodeMap.get(id);
                            return `${n.label || n.id}@${n.floorLevel}`;
                        }).join(" -> ");

                        const pathData = finalPath.map(id => {
                            const n = nodeMap.get(id);
                            return {
                                uid: n.uid,
                                id: n.id,
                                label: n.label || n.id,
                                floor: n.floorLevel,
                                kind: n.kind,
                                x: n.x,
                                y: n.y,
                                z: n.z
                            };
                        });

                        downloadJSON("route.json", pathData);

                        statusEl.textContent = `Done. Cost=${gScore.get(currentGoalId).toFixed(2)} | ${routeText}`;
                        render([], [...closedSet], current, finalPath);
                        return;
                    }

                    openSet.delete(current);
                    closedSet.add(current);

                    for (const edge of adjacency.get(current) || []) {
                        if (closedSet.has(edge.to)) continue;

                        const tentativeG = gScore.get(current) + edge.cost;

                        if (!openSet.has(edge.to)) openSet.add(edge.to);
                        else if (tentativeG >= gScore.get(edge.to)) continue;

                        cameFrom.set(edge.to, current);
                        gScore.set(edge.to, tentativeG);
                        fScore.set(edge.to, tentativeG + heuristic(edge.to, currentGoalId));
                    }

                    step++;
                }

                statusEl.textContent = "No path found.";
                render([], [], null, []);
            }

            function buildCombinedGraph(files) {
                floors = files.map(d => ({
                    data: d,
                    floorLevel: d.project?.floorLevel ?? 1,
                    pixelsPerMeter: d.calibration?.pixelsPerMeter || 50
                })).sort((a, b) => a.floorLevel - b.floorLevel);

                const floorByLevel = new Map(floors.map(f => [f.floorLevel, f]));
                const holtPPM = floorByLevel.get(1)?.pixelsPerMeter || 16.41385;
                const campusPPM = floorByLevel.get(0)?.pixelsPerMeter || 1.28326;
                const campusScale = holtPPM / campusPPM;

                const FLOOR_SCALES = {
                    0: campusScale,
                    1: 1.0,
                    2: 1.0,
                    3: 1.0
                };

                const rawNodes = [];
                const walkwayEdges = [];
                const stairEdges = [];
                const elevatorEdges = [];
                const entryEdges = [];

                for (const floor of floors) {
                    for (const n of floor.data.nodes || []) {
                        rawNodes.push({
                            ...n,
                            uid: namespacedId(floor.floorLevel, n.id),
                            floorLevel: floor.floorLevel,
                            pixelsPerMeter: floor.pixelsPerMeter
                        });
                    }
                }

                const xs = rawNodes.map(n => n.x);
                const ys = rawNodes.map(n => n.y);
                const cx = (Math.min(...xs) + Math.max(...xs)) / 2;
                const cy = (Math.min(...ys) + Math.max(...ys)) / 2;

                allNodes = rawNodes.map(n => {
                    const scale = FLOOR_SCALES[n.floorLevel] ?? 1.0;
                    return {
                        ...n,
                        raw: { x: n.x, y: n.y },
                        x: (n.x - cx) * scale,
                        y: -(n.y - cy) * scale,
                        z: visualZForFloor(n.floorLevel)
                    };
                });

                nodeMap = new Map();
                adjacency = new Map();

                for (const n of allNodes) {
                    nodeMap.set(n.uid, n);
                    adjacency.set(n.uid, []);
                }

                // Same-floor edges
                for (const floor of floors) {
                    for (const e of floor.data.edges || []) {
                        const from = namespacedId(floor.floorLevel, e.from);
                        const to = namespacedId(floor.floorLevel, e.to);
                        const cost = Number.isFinite(e.lengthMeters) ? e.lengthMeters : 1.0;
                        walkwayEdges.push({ from, to });
                        addAdjEdge(from, to, cost, "walkway", !!e.bidirectional);
                    }
                }

                // Stairs: adjacent floors only
                for (let i = 0; i < floors.length - 1; i++) {
                    const low = allNodes.filter(n => n.floorLevel === floors[i].floorLevel && n.kind === "transition");
                    const high = allNodes.filter(n => n.floorLevel === floors[i + 1].floorLevel && n.kind === "transition");

                    for (const [a, b] of pairNearestTransitions(low, high)) {
                        stairEdges.push({ from: a.uid, to: b.uid });
                        addAdjEdge(a.uid, b.uid, STAIR_COST, "stairs", true);
                    }
                }

                // Elevators: all portals across floors
                const portals = allNodes.filter(n => n.kind === "portal");
                for (let i = 0; i < portals.length; i++) {
                    for (let j = i + 1; j < portals.length; j++) {
                        if (portals[i].floorLevel === portals[j].floorLevel) continue;
                        elevatorEdges.push({ from: portals[i].uid, to: portals[j].uid });
                        addAdjEdge(portals[i].uid, portals[j].uid, ELEVATOR_COST, "elevator", true);
                    }
                }

                // One outside approach node per Holt floor-1 entrance
                const floor1Entrances = allNodes.filter(n => n.floorLevel === 1 && n.kind === "entrance");
                const campusNodes = allNodes.filter(n => n.floorLevel === 0);

                for (const entrance of floor1Entrances) {
                    let chosenCampus = null;

                    const manualCampusId = MANUAL_ENTRANCE_BINDINGS[entrance.label];
                    if (manualCampusId) {
                        chosenCampus = allNodes.find(n => n.floorLevel === 0 && n.id === manualCampusId);
                    }

                    if (!chosenCampus) {
                        let bestDist = Infinity;
                        for (const campus of campusNodes) {
                            const d = distanceScaled(entrance, campus);
                            if (d < bestDist) {
                                bestDist = d;
                                chosenCampus = campus;
                            }
                        }
                    }

                    if (!chosenCampus) continue;

                    const exteriorNode = {
                        uid: `0:exterior-for-${entrance.id}`,
                        id: `exterior-for-${entrance.id}`,
                        label: `${entrance.label} Outside`,
                        kind: "entrance",
                        floorLevel: 0,
                        pixelsPerMeter: chosenCampus.pixelsPerMeter || campusPPM,
                        raw: {
                            x: chosenCampus.raw.x,
                            y: chosenCampus.raw.y
                        },
                        x: chosenCampus.x,
                        y: chosenCampus.y,
                        z: visualZForFloor(0)
                    };

                    addSyntheticNode(exteriorNode);

                    addAdjEdge(exteriorNode.uid, chosenCampus.uid, EXTERIOR_TO_CAMPUS_COST, "campus-entry", true);
                    entryEdges.push({ from: exteriorNode.uid, to: chosenCampus.uid });

                    addAdjEdge(exteriorNode.uid, entrance.uid, EXTERIOR_TO_BUILDING_COST, "building-entry", true);
                    entryEdges.push({ from: exteriorNode.uid, to: entrance.uid });
                }

                baseNodeTrace = {
                    type: "scatter3d",
                    mode: "markers",
                    name: "nodes",
                    x: allNodes.map(n => n.x),
                    y: allNodes.map(n => n.y),
                    z: allNodes.map(n => n.z),
                    text: allNodes.map(n => `${n.label || n.id} @ floor ${n.floorLevel} [${n.kind}]`),
                    hoverinfo: "text",
                    marker: {
                        size: 4,
                        color: allNodes.map(n => colorForKind(n.kind)),
                        opacity: 0.82
                    }
                };

                baseWalkwayTrace = buildLineTrace(walkwayEdges, "walkways", "lightgray", 3);
                baseStairTrace = buildLineTrace(stairEdges, "stairs", "saddlebrown", 6);
                baseElevatorTrace = buildLineTrace(elevatorEdges, "elevators", "teal", 6);
                baseEntryTrace = buildLineTrace(entryEdges, "entry links", "black", 5);

                statusEl.textContent =
                    `Loaded ${allNodes.length} nodes across ${floors.length} floors. Campus scale=${campusScale.toFixed(2)}x. Walkways=${walkwayEdges.length}, stairs=${stairEdges.length}, elevators=${elevatorEdges.length}, entry-links=${entryEdges.length}`;
            }

            async function init() {
                try {
                    const files = await Promise.all([
                        fetch("./campus-graph-map-editor.json").then(r => r.json()),
                        fetch("./holt-floor-1.json").then(r => r.json()),
                        fetch("./holt-floor-2.json").then(r => r.json()),
                        fetch("./holt-floor-3.json").then(r => r.json())
                    ]);

                    buildCombinedGraph(files);
                    render();
                } catch (err) {
                    console.error(err);
                    statusEl.textContent = "FAILED: " + err.message;
                }
            }

            runBtn.addEventListener("click", runAStar);

            resetBtn.addEventListener("click", () => {
                currentStartId = null;
                currentGoalId = null;
                statusEl.textContent =
                    `Loaded ${allNodes.length} nodes across ${floors.length} floors. Ready.`;
                render();
            });



            function downloadJSON(filename, data) {
                const blob = new Blob([JSON.stringify(data, null, 2)], {
                    type: "application/json"
                });

                const url = URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url;
                a.download = filename;
                a.click();

                URL.revokeObjectURL(url);
            }

            init();
        </script>
    </body>
</html>
